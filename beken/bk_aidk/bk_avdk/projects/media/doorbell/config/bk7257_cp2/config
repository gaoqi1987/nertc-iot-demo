#@ video data in dtcm
CONFIG_VIDEO_DTCM=y
#@ Enable Media
CONFIG_MEDIA_MINOR=y
#@ Enable media service
CONFIG_MEDIA=y
#@ Enable Cache
CONFIG_CACHE_ENABLE=n
#@ CPU0 RAM size for SPE
CONFIG_CPU0_SPE_RAM_SIZE=0X55000
#@ CPU1 app RAM size
CONFIG_CPU1_APP_RAM_SIZE=0x3F800
#@ CPU2 app RAM size
CONFIG_CPU2_APP_RAM_SIZE=0XB800
#@ Enable General DMA
CONFIG_GENERAL_DMA=n
#@ Enable SPI DMA
CONFIG_SPI_DMA=n
#@ 4
CONFIG_DMA_LOGIC_CHAN_CNT=7
#@ 0
CONFIG_DMA_LOGIC_CHAN_ID_MIN=9
