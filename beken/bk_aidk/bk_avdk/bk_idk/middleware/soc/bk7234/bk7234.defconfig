# CONFIG_ARCH_ARM9 is not set
# end of Arch::Arm9

#
# Arch::Cm33
#
#@ Enable Cortex-M33
CONFIG_ARCH_CM33=y

#
# Modify Arch Cm33 Config
#
#@ Enable FPGA
CONFIG_FPGA=y
#@ Enable Memory Protect Unit Feature
CONFIG_MPU=y
#@ Enable SPE
CONFIG_SPE=1
# CONFIG_ARCH_INT_STATIS is not set
#@ Systick use external 32K clock
CONFIG_SYSTICK_32K=y
#@ Enable Cache
CONFIG_CACHE_ENABLE=n
#@ Dump all memory when exception happen
CONFIG_MEMDUMP_ALL=y
# end of Modify Arch Cm33 Config
# end of Arch::Cm33

#
# Arch::Riscv
#
# CONFIG_ARCH_RISCV is not set
# end of Arch::Riscv

#
# Compal
#
# CONFIG_SUPPORT_MATTER is not set
# CONFIG_COMMON_IO is not set
# end of Compal

#
# Driver
#

#
# device
#
#@ Set maximum device name length
CONFIG_DEVICE_MAX_NAME_LEN=32
# CONFIG_DM is not set
# end of device

#
# Watchdog
#
#@ Enable Interrupt Watchdog
CONFIG_INT_WDT=y
#@ Interrupt Watchdog Period(ms)
CONFIG_INT_WDT_PERIOD_MS=8000
#@ Enable Task Watchdog
CONFIG_TASK_WDT=y
#@ Task Watchdog Period(ms)
CONFIG_TASK_WDT_PERIOD_MS=16000
#@ Enable NMI Watchdog
CONFIG_NMI_WDT_EN=y
# end of Watchdog


#
# AON_Watchdog
#
#@ Enable AON Watchdog
CONFIG_AON_WDT=n
#@ Enable Interrupt AON Watchdog
CONFIG_INT_AON_WDT=n
#@ Interrupt AON Watchdog Period(ms)
CONFIG_INT_AON_WDT_PERIOD_MS=1000
# end of AON_Watchdog

#
# UART
#
#@ Enable UART1
CONFIG_UART1=y
# CONFIG_UART1_FLOW_CTRL is not set
#@ Enable UART2
CONFIG_UART2=y
# CONFIG_UART3 is not set
#@ Default 0 mean use UART1
CONFIG_UART_PRINT_PORT=0
#@ Default 1 mean use UART2
CONFIG_UART_ATE_PORT=0
#@ The value should be changed if print size is more than 128
CONFIG_PRINTF_BUF_SIZE=256
# CONFIG_BACKGROUND_PRINT is not set
#@ This will set kfifo size when software uses kfifo to cache data receiving.
CONFIG_KFIFO_SIZE=128
# CONFIG_UART_STATIS is not set
#@ Enable UART support low power
CONFIG_UART_LOW_VOLTAGE_SUPPORT=y
#@ Enable UART support error interrupt
CONFIG_UART_ERR_INTERRUPT=y
# CONFIG_UART_RX_DMA is not set
#@ This will reset kfifo size of "CONFIG_KFIFO_SIZE" when software enable rx dma.
CONFIG_UART_RX_DMA_KFIFO_SIZE=512
#@ Enable UART enter low voltage callback support
CONFIG_UART_PM_CB_SUPPORT=y
# end of UART

#
# TRNG
#
#@ Support hardware TRNG
CONFIG_TRNG_SUPPORT=y
# end of TRNG

#
# SDIO_HOST
#
#@ Enable sdio host
CONFIG_SDIO_HOST=n
#@ SDIO Host default clock freq
CONFIG_SDIO_HOST_DEFAULT_CLOCK_FREQ=1
#@ SDIO CLEAR WRITE INT NEED WAIT
CONFIG_SDIO_HOST_CLR_WRITE_INT=y
#@ SDIO PM Support
CONFIG_SDIO_PM_CB_SUPPORT=y
# end of SDIO_HOST

#
# SDCARD
#
#@ Enable SDCARD
CONFIG_SDCARD=n
#@ sd card default clock freq
CONFIG_SDCARD_DEFAULT_CLOCK_FREQ=11
# CONFIG_SDCARD_BUSWIDTH_4LINE is not set
#@ Enable SDcard power gpio ctrl
CONFIG_SDCARD_POWER_GPIO_CTRL=y
# end of SDCARD

#
# FATFS
#
#@ Support FATFS
CONFIG_FATFS=n
#@ Support SDCARD FATFS
CONFIG_FATFS_SDCARD=n
# end of FATFS

#
# SDIO
#
#@ Enable SDIO
CONFIG_SDIO=n
# CONFIG_SDIO_V1P0 is not set
#@ SDIO Version V2P0
CONFIG_SDIO_V2P0=y
# CONFIG_SDIO_SLAVE is not set
# CONFIG_SDIO_4LINES_EN is not set
# end of SDIO

#
# SPI
#
#@ Enable SPI DMA
CONFIG_SPI_DMA=n
#@ Enable SPI Statis
CONFIG_SPI_STATIS=y
#@ Support TX FIFO Write Ready
CONFIG_SPI_SUPPORT_TX_FIFO_WR_READY=y
#@ SPI PM Support
CONFIG_SPI_PM_CB_SUPPORT=y
#@ SPI MST Flash
CONFIG_SPI_MST_FLASH=y
# end of SPI

#
# QSPI
#
#@ Enable QSPI
CONFIG_QSPI=y
#@ Enable QSPI Statis
CONFIG_QSPI_STATIS=y
#@ Enable GD Flash
CONFIG_QSPI_FLASH_GD=y
# end of QSPI

#
# AON_RTC
#
#@ Enable AON_RTC
CONFIG_AON_RTC=y
#@ Enable AON_RTC_64BIT
CONFIG_AON_RTC_64BIT=y
#@ Enable AON_RTC support many users
CONFIG_AON_RTC_MANY_USERS=y
#@ Enable AON_RTC Test,F.E:Command line test
CONFIG_AON_RTC_TEST=y
# CONFIG_AON_RTC_DEBUG is not set
# CONFIG_AON_RTC_KEEP_TIME_SUPPORT is not set
#@ This is for super deep sleep
CONFIG_RTC_ANA_WAKEUP_SUPPORT=y
# CONFIG_AON_RTC_DYNAMIC_CLOCK_SUPPORT is not set
# end of AON_RTC

#
# GPIO
#
#@ Enable GPIO WAKEUP system if at low voltage status
CONFIG_GPIO_WAKEUP_SUPPORT=y
#@ Enable GPIO dynamic config to wake system if at low volatage status
CONFIG_GPIO_DYNAMIC_WAKEUP_SUPPORT=y
# CONFIG_GPIO_WAKEUP_DEBUG is not set
#@ The value should be changed if need more then 4 gpio
CONFIG_GPIO_DYNAMIC_WAKEUP_SOURCE_MAX_CNT=4
#@ Only one port is supported for now
CONFIG_CONFIG_GPIO_WAKEUP_ID=22
#@ 0: set gpio as low level intterrupt type
CONFIG_CONFIG_GPIO_WAKEUP_INT_TYPE=0
# CONFIG_GPIO_SIMULATE_UART_WRITE is not set
#@ Enable GPIO default set devs
CONFIG_GPIO_DEFAULT_SET_SUPPORT=y
#@ This is for super deep sleep
CONFIG_GPIO_ANA_WAKEUP_SUPPORT=y
# end of GPIO

#
# AON_PMU
#
#@ Enable AON_PMU
CONFIG_AON_PMU=y
# end of AON_PMU

#
# GENERAL_DMA
#
#@ Enable General DMA
CONFIG_GENERAL_DMA=y
#@ GDMA HW version v2px in ASIC
CONFIG_GDMA_HW_V2PX=y
#@ 4
CONFIG_DMA_LOGIC_CHAN_CNT=16
#@ 0
CONFIG_DMA_LOGIC_CHAN_ID_MIN=0   #logic chan id is in [0~15] (MIN value is 0, and DMA_LOGIC_CHAN_CNT=16)
# end of GENERAL_DMA

#
# TOUCH
#
#@ Enable TOUCH
CONFIG_TOUCH=y
# CONFIG_TOUCH_INTERNAL_SERIAL_CAP is not set
# CONFIG_TOUCH_PM_SUPPORT is not set
# end of TOUCH

#
# SBC
#
# CONFIG_SBC is not set
# end of SBC

#
# JPEG_ENC
#
#@ Enable HardWare JPEG ENCODE
CONFIG_JPEGENC_HW=y
# end of JPEG_ENC

#
# JPEG_DEC
#
#@ Enable JPEGDEC Display
CONFIG_JPEGDEC_HW=y
# end of JPEG_DEC

#
# PSRAM
#
#@ Enable PSRAM
CONFIG_PSRAM=y
#@ Select Psram PSRAM_APS6408L_O
CONFIG_PSRAM_APS6408L_O=y
# CONFIG_PSRAM_W955D8MKY_5J is not set
#@ Enable psram_malloc API
CONFIG_PSRAM_AS_SYS_MEMORY=y
#@ The psram address is from 0x60000000 to 0x60800000 for psram aps6408l_o
CONFIG_PSRAM_HEAP_BASE=0x60700000
#@ psram aps6408l-o
CONFIG_PSRAM_HEAP_SIZE=0x80000
#@ Enable PSRAM write through
CONFIG_PSRAM_WRITE_THROUGH=y
#@ Enable PSRAM calibrate
CONFIG_PSRAM_CALIBRATE=y
# end of PSRAM

#
# CALENDAR
#
# CONFIG_CALENDAR is not set
# end of CALENDAR

#
#
CONFIG_GPIO_GROUP0_SECURE_BITMAP=0
CONFIG_GPIO_GROUP1_SECURE_BITMAP=0
CONFIG_AHB_DEV_SECURE_BITMAP=0
CONFIG_APB_DEV_SECURE_BITMAP=0
CONFIG_AHB_PRIVILEGE_BITMAP=0
CONFIG_APB_PRIVILEGE_BITMAP=0
# end of PRRO

#
# SYS_CTRL
#
# CONFIG_SYS_REDUCE_NORMAL_POWER is not set
# CONFIG_XTAL_FREQ_40M is not set
#@ XTAL frequency 26M
CONFIG_XTAL_FREQ_26M=y
#@ 26000000
CONFIG_XTAL_FREQ=26000000
#@ DCO frequency
CONFIG_DCO_FREQ=120000000
#@ Enable system_ctrl
CONFIG_SYSTEM_CTRL=y
#@ system_ctrl debug
CONFIG_HAL_DEBUG_SYS=y
# CONFIG_POWER_CLOCK_RF is not set
#@ Enable system clock
CONFIG_SYSTEM_CLOCK=y
# CONFIG_ROSC_TEST_MODE is not set
#@ Default low power clock source
CONFIG_DEFAULT_LPO_SRC=2
# CONFIG_CPU0_SUB_POWER_DOMAIN_ENA is not set
#@ Enable LDO self low power mode
CONFIG_LDO_SELF_LOW_POWER_MODE_ENA=y
# end of SYS_CTRL

#
# PHY
#
# CONFIG_PTA is not set
#@ Enable MAC/PHY by pass mode
CONFIG_MAC_PHY_BYPASS=y
# end of PHY

#
# I2S
#
#@ Enable I2S
CONFIG_I2S=y
# end of I2S

#
# I2C
#
#@ Enable I2C
CONFIG_I2C=y
#@ The value should be changed if need to change i2c id
CONFIG_I2C_SUPPORT_ID_BITS=3
#@ i2c pm support
CONFIG_I2C_PM_CB_SUPPORT=y
# CONFIG_FM_I2C is not set
# CONFIG_SIM_I2C is not set
# end of I2C

#
# AUDIO
#
# CONFIG_AUDIO_RISCV_IP_V1_0 is not set
# CONFIG_AUDIO_DSP_IP_V1_0 is not set
# end of AUDIO

#
# PWM
#
#@ Enable pwm
CONFIG_PWM=y
# CONFIG_PWM_V0P0 is not set
#@ "ASIC PWM IP Version V1P1:BK7236XX...,the chips MP after 2023-04"
CONFIG_PWM_V1PX=y
# CONFIG_PWM_HAS_TWO_INT is not set
#@ PWM PM Support
CONFIG_PWM_PM_CB_SUPPORT=y
# end of PWM

#
# ICU
#
# CONFIG_ICU_GPIO is not set
# end of ICU

#
# Interrupt
#
# CONFIG_ISR_REG_DISABLE is not set
# end of Interrupt

#
# TIMER
#
#@ Enable TIMER
CONFIG_TIMER=y
#@ Enable timer counter
CONFIG_TIMER_COUNTER=y
#@ 0 indicates that all IDs are supported by default, no configuration required
CONFIG_TIMER_SUPPORT_ID_BITS=63
#@ Enable timer0 as microsecond timer
CONFIG_TIMER_US=y
#@ Enable TIMER enter low voltage callback support
CONFIG_TIMER_PM_CB_SUPPORT=y
# end of TIMER

#
# SARADC
#
#@ Enable saradc
CONFIG_SARADC=y
# CONFIG_SARADC_NEED_FLUSH is not set
#@ Enable saradc measure range divide
CONFIG_SARADC_RANGE_DIVIDE=y
#@ saradc pm support
CONFIG_SARADC_PM_CB_SUPPORT=y
# end of SARADC

#
# FLASH
#
#@ Enable flash
CONFIG_FLASH=y
#@ Enable flash quad enable
CONFIG_FLASH_QUAD_ENABLE=y
# CONFIG_FLASH_SRC_CLK_60M is not set
# CONFIG_FLASH_ORIGIN_API is not set
# end of FLASH

#
# H264_CONFIG
#
#@ Enable h264
CONFIG_H264=y
# end of H264_CONFIG

#
# SDMADC
#
#@ Enable sdmadc
CONFIG_SDMADC=y
# end of SDMADC

#
# PWR_CLK
#
#@ Use an external 32k crystal
CONFIG_EXTERN_32K=n
#@ 32k use the 26m divide
CONFIG_LPO_SRC_26M32K=n
#@ buck enable
CONFIG_BUCK_ENABLE=y
#@ bakp power domain disable
CONFIG_BAKP_POWER_DOMAIN_DISABLE=y
#@ psram power domain disable
CONFIG_PSRAM_POWER_DOMAIN_LV_DISABLE=y
#@ ahbp power domain disable
CONFIG_AHBP_POWER_DOMAIN_LV_DISABLE=y
#@ set cpu default frequency 60M
CONFIG_CPU_DEFAULT_FREQ_60M=y
#@ enable vbspbuflp1v
CONFIG_VBSPBUFLP1V_ENABLE=y
#@ enable calibrate rc32k by software
CONFIG_ROSC_CALIB_SW=y
#@ Set Low power voltage default value 0.6v(0.45+0.025*6)
CONFIG_LP_VOL=0x6
#@ enable dig ldo low voltage
CONFIG_DIGLDO_LOW_VOLTAGE_ENABLE=y
# end of PWR_CLK

#
# VAULT
#
# CONFIG_VAULT_SUPPORT is not set
# end of VAULT

#
# OTP
#
#@ Enable OTP
CONFIG_OTP=n
#@ Use OTP to save rfcali data
CONFIG_PHY_RFCALI_TO_OTP=n
# end of OTP

#
# CKMN
#
#@ Enable CKMN
CONFIG_CKMN=y
# end of CKMN

#
# HW_ROTATE
#
#@ Enable hw rotate and pixel convert module
CONFIG_HW_ROTATE_PFC=y
# end of HW_ROTATE

#
# YUV_BUF
#
#@ Enable yuv_buf
CONFIG_YUV_BUF=y
# end of YUV_BUF

#
# LCD
#
#@ Enable LCD
CONFIG_LCD=y
#@ Enable LCD_GC9503V API
CONFIG_LCD_GC9503V=y
#@ Enable LCD_H050IWV API
CONFIG_LCD_H050IWV=y
#@ Enable LCD_HX8282 API
CONFIG_LCD_HX8282=y
#@ Enable LCD_MD0430R API
CONFIG_LCD_MD0430R=y
#@ Enable LCD_MD0700R API
CONFIG_LCD_MD0700R=y
#@ Enable LCD_NT35512 API
CONFIG_LCD_NT35512=y
#@ Enable LCD_NT35510 API
CONFIG_LCD_NT35510=y
#@ Enable LCD_NT35510_MCU API
CONFIG_LCD_NT35510_MCU=y
#@ Enable LCD_ST7282 API
CONFIG_LCD_ST7282=y
#@ Enable LCD_ST7796S API
CONFIG_LCD_ST7796S=y
# CONFIG_LCD_ST7710S is not set
# CONFIG_LCD_ST7701S is not set
# CONFIG_LCD_ST7701S_LY is not set
# CONFIG_LCD_ST7789V is not set
# CONFIG_LCD_QSPI is not set
# CONFIG_LCD_POWER_GPIO_CTRL is not set
# CONFIG_LCD_BACKLIGHT_GPIO_CTRL is not set
# end of LCD

#
# IRDA
#
# CONFIG_IRDA is not set
# end of IRDA

#
# CAMERA
#
#@ Enable camera interface
CONFIG_DVP_CAMERA=y
#@ The value should be changed if need to change i2c id
CONFIG_DVP_CAMERA_I2C_ID=1
# CONFIG_CAMERA_POWER_GPIO_CTRL is not set
# CONFIG_ENCODE_BUF_DYNAMIC is not set
#@ current ip support 72M pclk
CONFIG_DVP_PCLK_72M=y
# end of CAMERA

#
# RESET_REASON
#
#@ Enable reset reason
CONFIG_RESET_REASON=y
# end of RESET_REASON

#
# EFUSE
#
# end of EFUSE

#
# MAILBOX
#
#@ Enable mail_box
CONFIG_MAILBOX=y
#@ Use mailbox v2.0 driver
CONFIG_MAILBOX_V2_0=y
# end of MAILBOX

#
# TP
#
# CONFIG_TP is not set
# end of TP

#
# DMA2D
#
#@ Enable DMA2D
CONFIG_DMA2D=y
# end of DMA2D

#
# RX_OPTIMIZE
#
#@ Optimize rx current
CONFIG_RX_OPTIMIZE=n
# end of RX_OPTIMIZE

# LIN
#
#@ Enable LIN
CONFIG_LIN=n
#@ This device is the master
CONFIG_LIN_DEVICE_MASTER=n
# end of LIN

#
# SOFTWARE_SUPPORT_CHIP
#
# CONFIG_CHIP_SUPPORT is not set
# end of SOFTWARE_SUPPORT_CHIP
# end of Driver

#
# bk7234
#
#@ Total ITCM size
CONFIG_ITCM_SIZE=0x4000
#@ Total DTCM size
CONFIG_DTCM_SIZE=0x3FE0
#@ CPU0 RAM size for SPE
CONFIG_CPU0_SPE_RAM_SIZE=0xA0000
#@ CPU0 RAM size for NSPE
CONFIG_CPU0_NSPE_RAM_SIZE=0x40000
#@ CPU1 app RAM size
CONFIG_CPU1_APP_RAM_SIZE=0x00000
# CONFIG_ANA_REG_WRITE_POLL_REG_B is not set
# CONFIG_PM_HAL_DEBUG is not set
# CONFIG_PM_HAL_CTRL is not set
# end of bk7234

#
# VENDOR CAL CONFIG
#
#@ Enable vendor cal
CONFIG_VND_CAL=y
#@ Enable high power level
CONFIG_BLE_USE_HIGH_POWER_LEVEL=n
# end of VENDOR CAL CONFIG

#
# Boards::Bk7234::Vnd_flash
#
# CONFIG_OVERRIDE_FLASH_PARTITION is not set
# end of Boards::Bk7234::Vnd_flash
# end of Middleware Configuration

