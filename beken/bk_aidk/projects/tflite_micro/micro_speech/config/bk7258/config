#@ Enable Override Flash Partition
CONFIG_OVERRIDE_FLASH_PARTITION=y
#@ CPU0 RAM size for SPE
CONFIG_CPU0_SPE_RAM_SIZE=0X3C000
#@ CPU1 app RAM size
CONFIG_CPU1_APP_RAM_SIZE=0X64000
#@ CPU2 app RAM size
CONFIG_CPU2_APP_RAM_SIZE=0X0000
#@ Enable Memory Protect Unit Feature
CONFIG_MPU=y
#@ Enable Cache
CONFIG_CACHE_ENABLE=n
#@ When this option is enable, more memory will be consumed because
CONFIG_MEM_DEBUG=n
#@ Use an external 32k crystal
CONFIG_EXTERN_32K=n
#@ 32k use the 26m divide
CONFIG_LPO_SRC_26M32K=y
#@ Enable PSRAM write through
CONFIG_PSRAM_WRITE_THROUGH=y
#@ BT reuse media memory at beging of cpu1
CONFIG_BT_REUSE_MEDIA_MEMORY=y
#@ BT reuse media memory size
CONFIG_BT_REUSE_MEDIA_MEM_SIZE=0x1B000
#@ System tick count per second, can be 1-1000
CONFIG_FREERTOS_TICK_RATE_HZ=1000
#@ Set the size of the heap memory. The recommended value is 51200 .
CONFIG_LWIP_MEM_SIZE=89600
#@ Set the size of the max memory tx used. The recommended value is
CONFIG_LWIP_MEM_MAX_TX_SIZE=40200
#@ Set the size of the max memory rx used. The recommended value is
CONFIG_LWIP_MEM_MAX_RX_SIZE=40600
#@ use fast connect
CONFIG_WIFI_FAST_CONNECT=y
#@ Enable Wifi Default Connect
CONFIG_ENABLE_WIFI_DEFAULT_CONNECT=y
#@ use previous dhcp ip address
CONFIG_WIFI_FAST_DHCP=y
#@ Set transfer app task size
CONFIG_TRANS_APP_TASK_SIZE=1024
#@ Audio ring buff safe interval
CONFIG_AUD_RING_BUFF_SAFE_INTERVAL=4
#@ 0
CONFIG_DMA_LOGIC_CHAN_ID_MIN=0
#@ Enable USB
CONFIG_USB=n
#@ MENTOR_USB
CONFIG_MENTOR_USB=n
#@ CHERRY_USB
CONFIG_CHERRY_USB=n
#@ Enable USB Host Mode
CONFIG_USB_HOST=n
#@ Enable USB Device Mode
CONFIG_USB_DEVICE=n
#@ Priority of USB task
CONFIG_TASK_USB_PRIO=5
#@ Enable Usb Uvc
CONFIG_USB_UVC=n
#@ Enable Usb Uac
CONFIG_USB_UAC=n
#@ Enable Usb Uac Mic
CONFIG_USB_UAC_MIC=n
#@ Enable Usb Uac Speaker
CONFIG_USB_UAC_SPEAKER=n
#@ Enable fusion device video and audio
CONFIG_UVC_UAC_DEMO=n
#@ Enable Usb Uvc_Uac Debug
CONFIG_UVC_UAC_DEMO_DEBUG=n
#@ Enable Multi-core operation USB
CONFIG_USB_MAILBOX=n
#@ Enable USB mailbox master
CONFIG_USB_MAILBOX_MASTER=n
#@ Enable USB mailbox slave
CONFIG_USB_MAILBOX_SLAVE=n
#@ Enable Iperf Test
CONFIG_IPERF_TEST=n
#@ Enable touch demos
CONFIG_TOUCH_TEST=n
#@ Enable Aon Pmu Test
CONFIG_AON_PMU_TEST=n
#@ Enable Audio driver test
CONFIG_AUDIO_TEST=n
#@ Enable I2S Test
CONFIG_I2S_TEST=n
#@ Enable TOUCH
CONFIG_TOUCH=n
#@ Enable Psram Test
CONFIG_PSRAM_TEST=n
#@ Enable Interrupt Test
CONFIG_INTERRUPT_TEST=n
#@ Set psram_malloc base address
CONFIG_PSRAM_HEAP_CPU0_BASE_ADDER=0x60700000
#@ The psram address is from 0x60000000 to 0x60800000 for psram aps6408l_o
CONFIG_PSRAM_HEAP_BASE=0x60700000
#@ psram aps6408l-o
CONFIG_PSRAM_HEAP_SIZE=0x10000
#@ Cpu1 core offset address default 0x2e0000
CONFIG_SYS_CPU1_OFFSET=0x21d0000
