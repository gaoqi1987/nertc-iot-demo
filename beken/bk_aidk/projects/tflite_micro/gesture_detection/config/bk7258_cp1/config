#@ Enable Override Flash Partition
CONFIG_OVERRIDE_FLASH_PARTITION=y
#
#@ CPU0 RAM size for SPE
CONFIG_CPU0_SPE_RAM_SIZE=0X3C000
#@ CPU1 app RAM size
CONFIG_CPU1_APP_RAM_SIZE=0X64000
#@ CPU2 app RAM size
CONFIG_CPU2_APP_RAM_SIZE=0X0000
#
#@ Enable Memory Protect Unit Feature
CONFIG_MPU=y
#
#@ Enable Cache
CONFIG_CACHE_ENABLE=n
#
#@ When this option is enable, more memory will be consumed because
CONFIG_MEM_DEBUG=n
#
#@ Enable PSRAM write through
CONFIG_PSRAM_WRITE_THROUGH=y
#@ Use psram_malloc at os_malloc failed.
CONFIG_USE_PSRAM_HEAP_AT_SRAM_OOM=y
#
#@ BT reuse media memory at beging of cpu1
CONFIG_BT_REUSE_MEDIA_MEMORY=y
#@ BT reuse media memory size
CONFIG_BT_REUSE_MEDIA_MEM_SIZE=0x1B000
#
#@ video data in dtcm
CONFIG_VIDEO_DTCM=y
#
#@ Enable Lcd scale
CONFIG_MEDIA_SCALE=y
#@ Enable Lcd scale
CONFIG_MEDIA_PIPELINE=y
#
# CONFIG_SUPPORTED_IMAGE_MAX_720P=y
#
# CONFIG_H264_P_FRAME_CNT=5
#@ config a h264 NALU size unit(byte), default 64k
CONFIG_H264_FRAME_SIZE=81920
#@ set h264 compress quality level
CONFIG_H264_QUALITY_LEVEL=0
#@ Enable function add sei nalu for self define, contain frame information
CONFIG_H264_ADD_SELF_DEFINE_SEI=n
#
#@ Audio Transfer DAC PA Control Enable
CONFIG_AUD_TRAS_DAC_PA_CTRL=n
#@ Audio ring buff safe interval
CONFIG_AUD_RING_BUFF_SAFE_INTERVAL=4
# LCD
#@ Enable LCD QSPI
CONFIG_LCD_QSPI=n
#@ enable lcd blend by font logo
CONFIG_LCD_FONT_BLEND=y
#@ enable lcd dma2d blend flash logo
CONFIG_LCD_DMA2D_BLEND=n
# lVGL
CONFIG_LV_USE_DEMO_METER=y
#@ Enable Lvgl
CONFIG_LVGL=n
#@ Enable TP
CONFIG_TP=n
#@ Enable TP_GT911 API
CONFIG_TP_GT911=n
#@ Enable TP_GT1151 API
CONFIG_TP_GT1151=n
#@ 1 - 1 byte per pixel
CONFIG_LV_COLOR_DEPTH=16
#@ Enable Lv Font Montserrat 14
CONFIG_LV_FONT_MONTSERRAT_14=y
#@ Enable Lv Font Montserrat 24
CONFIG_LV_FONT_MONTSERRAT_24=y
#@ Enable Lv Font Montserrat 32
CONFIG_LV_FONT_MONTSERRAT_32=y
#@ Show CPU usage and FPS count
CONFIG_LV_USE_PERF_MONITOR=n
#@ Enable Lv Attribute Fast Mem
CONFIG_LV_ATTRIBUTE_FAST_MEM=n
#@ Enable use direct mode in LVGL use psram draw buffer
CONFIG_LVGL_USE_DIRECT_MODE=y
#@ Set lvgl task priority
CONFIG_LVGL_TASK_PRIORITY=5
#@ Enable lvgl task sleep time custimize
CONFIG_LVGL_TASK_SLEEP_TIME_CUSTOMIZE=y
#
#@ Enable GPIO Simulate I2C
CONFIG_SIM_I2C=y
#@ sim i2c with bk7258 hardware board v3
CONFIG_SIM_I2C_HW_BOARD_V3=n
#
#@ 4
CONFIG_DMA_LOGIC_CHAN_CNT=5
#@ 0
CONFIG_DMA_LOGIC_CHAN_ID_MIN=4
#
#@ Enable USB
CONFIG_USB=y
#@ USB VBAT CONTROL GPIO ID
CONFIG_USB_VBAT_CONTROL_GPIO_ID=0x1C
#@ MENTOR_USB
CONFIG_MENTOR_USB=n
#@ CHERRY_USB
CONFIG_CHERRY_USB=n
#@ Enable USB Host Mode
CONFIG_USB_HOST=n
#@ Enable USB Device Mode
CONFIG_USB_DEVICE=n
#@ Priority of USB task
CONFIG_TASK_USB_PRIO=5
#@ Enable Usb Uvc
CONFIG_USB_UVC=y
#@ Enable Usb Uac
CONFIG_USB_UAC=y
#@ Enable Usb Uac Mic
CONFIG_USB_UAC_MIC=n
#@ Enable Usb Uac Speaker
CONFIG_USB_UAC_SPEAKER=n
#@ Enable fusion device video and audio
CONFIG_UVC_UAC_DEMO=n
#@ Enable Usb Uvc_Uac Debug
CONFIG_UVC_UAC_DEMO_DEBUG=n
#@ Enable Multi-core operation USB
CONFIG_USB_MAILBOX=y
#@ Enable USB mailbox master
CONFIG_USB_MAILBOX_MASTER=y
#@ Enable USB mailbox master cpu1 to cpu2
CONFIG_USB_MAILBOX_MASTER_CPU1_TO_CPU2=y
#@ Enable USB mailbox slave
CONFIG_USB_MAILBOX_SLAVE=n
#
#@ Enable dvp Camera Test
CONFIG_DVP_CAMERA_TEST=n
#@ Enable Aon Pmu Test
CONFIG_AON_PMU_TEST=n
#@ Enable sdmadc
CONFIG_SDMADC=n
#@ Enable Sdmadc Test
CONFIG_SDMADC_TEST=n
#@ Enable Interrupt Test
CONFIG_INTERRUPT_TEST=n
#@ Enable Psram Test
CONFIG_PSRAM_TEST=n
#@ Enable I2S
CONFIG_I2S=n
#@ Enable I2S Test
CONFIG_I2S_TEST=n
#@ Enable Audio driver test
CONFIG_AUDIO_TEST=n

#@ Enable Face Detection
CONFIG_FACE_DETECTION=n

#@ Set psram_malloc base address
CONFIG_PSRAM_HEAP_CPU0_BASE_ADDER=0x60700000
#@ The psram address is from 0x60000000 to 0x60800000 for psram aps6408l_o
CONFIG_PSRAM_HEAP_BASE=0x60710000
#@ psram aps6408l-o
CONFIG_PSRAM_HEAP_SIZE=0x200000
#CONFIG_CACHE_ENABLE=y

#@ Enable TFLite Micro
CONFIG_TFLITE_MICRO=y
